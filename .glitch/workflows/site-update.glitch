;; site-update.glitch — regenerate all docs via AI, verify, build
;;
;; Each page gets rewritten by tiered LLM using real repo context.
;; Triple gate catches hallucinations before anything ships.
;; Changelog summarized by copilot.
;;
;; Run with: glitch workflow run site-update

(workflow "site-update"
  :description "AI-regenerate all docs, verify, build"

  ;; ── Gather context (shell, 0 tokens) ──────────────

  (step "stubs"
    (run "cat docs/site/*.md"))

  (step "examples"
    (run "for f in examples/*.glitch; do echo '=== '$f' ==='; cat \"$f\"; echo; done"))

  (step "workflows"
    (run "for f in .glitch/workflows/*.glitch; do echo '=== '$f' ==='; cat \"$f\"; echo; done"))

  (step "repo-structure"
    (run "find internal/ cmd/ -name '*.go' -not -path '*/testdata/*' | head -50"))

  (step "changelog-raw"
    (run "git log --oneline --since='2025-01-01' -- cmd/ internal/ examples/ .glitch/ docs/site/"))

  ;; ── Regenerate all pages (tiered — local first) ───

  (step "enrich-docs"
    (llm
      :format "json"
      :prompt ```
        You are a technical writer for gl1tch (8op.org).

        RULES:
        - "your" framing throughout, never "the user"
        - examples before explanation
        - no internal implementation details (no BubbleTea, tmux, SQLite, Go types)
        - every code example must come from the Real Examples or Workflows below
        - do NOT invent commands, flags, or features
        - preserve each stub's structure and headings — expand and improve, don't reorganize
        - be thorough but concise

        Your job: expand each stub into a polished documentation page.

        Output as a JSON array:
        [{"slug": "getting-started", "title": "...", "order": 1, "description": "...", "content": "markdown body"}]

        STUBS (your starting point):
        ~(step stubs)

        REAL EXAMPLES (use verbatim):
        ~(step examples)

        REAL WORKFLOWS:
        ~(step workflows)

        REPO STRUCTURE:
        ~(step repo-structure)
        ```))

  ;; ── Save with fallback ────────────────────────────

  (step "save-docs"
    (run "python3 scripts/save-enrich-docs.py < '~(stepfile enrich-docs)'"))

  (step "split-docs"
    (run "python3 scripts/split-docs.py"))

  ;; ── Changelog ─────────────────────────────────────

  (step "enrich-changelog"
    (llm
      :provider "copilot"
      :prompt ```
        Summarize these git commits into user-facing changelog entries.
        Group by feature area (workflow engine, providers, CLI, plugins, docs).
        Skip purely internal refactors unless they change user-visible behavior.
        Output as markdown. Each entry: ### heading, then bullet points.

        Commits:
        ~(step changelog-raw)
        ```))

  (step "save-changelog"
    (save "site/generated/changelog.md" :from "enrich-changelog"))

  ;; ── Triple gate (retries once on failure) ─────────

  (phase "verify" :retries 1
    (gate "no-hallucinations"
      (run "python3 scripts/gate-hallucinations.py"))
    (gate "stub-coverage"
      (run "python3 scripts/gate-coverage.py"))
    (gate "structure-and-tone"
      (run "python3 scripts/gate-structure.py")))

  ;; ── Build ─────────────────────────────────────────

  (step "build-report"
    (run "echo 'PASS' > site/generated/build-report.md && echo 'All gates passed.'"))

  (step "build-site"
    (run "cd site && npx astro build 2>&1"))

  (step "done"
    (run "echo 'Site built to site/dist/'")))
