;; discard-demo.glitch — demonstrate #_ reader discard for toggling steps
;;
;; Run with: glitch pipeline run examples/discard-demo.glitch
;;
;; The #_ prefix comments out an entire s-expression at read time.
;; Use it to disable steps without deleting them.

(def model "qwen2.5:7b")

(workflow "discard-demo"
  :description "Show how #_ discard works for toggling steps on and off"

  (step "data"
    (run "echo 'some input data'"))

  ;; This step is disabled — remove #_ to re-enable
  #_(step "expensive-analysis"
    (llm
      :model model
      :prompt ```
        Do a very thorough analysis of:
        {{step "data"}}
        ```))

  ;; This step runs instead
  (step "quick-analysis"
    (llm
      :model model
      :prompt ```
        Briefly summarize:
        {{step "data"}}
        ```)))
