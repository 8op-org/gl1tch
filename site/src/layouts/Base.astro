---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'GLITCH',
  description = 'A terminal workspace for AI-assisted development. Pipelines, agents, brain context — in your terminal.',
} = Astro.props;

const pageTitle = title === 'GLITCH' ? title : `${title} — GLITCH`;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={description} />
  <link rel="stylesheet" href="/css/bbs.css" />
</head>
<body>
  <canvas id="hexbg" aria-hidden="true"></canvas>
  <slot />
</body>
</html>
