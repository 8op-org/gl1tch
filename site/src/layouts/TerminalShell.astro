---
import Base from './Base.astro';
import Nav from '../components/Nav.astro';
import HelpOverlay from '../components/HelpOverlay.astro';

interface Props {
  title: string;
  description?: string;
}
const { title, description } = Astro.props;
---
<Base title={title} description={description}>
  <div class="terminal-shell">
    <Nav />
    <noscript>
      <div style="color:var(--yellow);padding:4px 16px;background:var(--current-line);font-family:monospace;font-size:11px">
        &#9888; Keyboard navigation requires JavaScript. All content is accessible below.
      </div>
    </noscript>
    <div class="screens-container">
      <slot />
    </div>
    <div class="status-bar">
      <span class="sb-brand">ORCAI</span>
      <span class="sb-keys">
        <span class="sb-key">1</span> home
        <span class="sb-sep">&nbsp;&middot;&nbsp;</span>
        <span class="sb-key">2</span> about
        <span class="sb-sep">&nbsp;&middot;&nbsp;</span>
        <span class="sb-key">3</span> start
        <span class="sb-sep">&nbsp;&middot;&nbsp;</span>
        <span class="sb-key">4</span> plugins
        <span class="sb-sep">&nbsp;&middot;&nbsp;</span>
        <span class="sb-key">5</span> pipes
        <span class="sb-sep">&nbsp;&middot;&nbsp;</span>
        <span class="sb-key">6</span> log
        <span class="sb-sep">&nbsp;&middot;&nbsp;</span>
        <span class="sb-key">7</span> themes
        <span class="sb-sep">&nbsp;&middot;&nbsp;</span>
        <span class="sb-key">8</span> labs
        <span class="sb-sep">&nbsp;&middot;&nbsp;</span>
        <span class="sb-key">9</span> docs
        <span class="sb-sep">&nbsp;&middot;&nbsp;</span>
        <span class="sb-key">?</span> help
        <span class="sb-sep">&nbsp;&middot;&nbsp;</span>
        <span class="sb-key">q</span> quit
      </span>
      <span class="clock"></span>
    </div>
  </div>
  <HelpOverlay />
</Base>
