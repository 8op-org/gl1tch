---
---
<div class="help-overlay" id="help-overlay" role="dialog" aria-modal="true" aria-label="Keyboard shortcuts">
  <div style="font-family:'JetBrains Mono',monospace;color:var(--green);font-size:13px;margin-bottom:12px;text-align:center;letter-spacing:2px">
    GL1TCH — KEYBOARD REFERENCE
  </div>
  <div class="help-content" style="font-family:'JetBrains Mono',monospace;font-size:12px;line-height:2;max-width:500px">
    <div style="color:var(--comment);margin-bottom:8px;letter-spacing:2px">SCREENS</div>
    <div><span style="color:var(--yellow)">1–7</span> <span style="color:var(--fg)">HOME · ABOUT · GET STARTED · PLUGINS · PIPELINES · CHANGELOG · THEMES</span></div>
    <div><span style="color:var(--yellow)">8</span> <span style="color:var(--fg)">LABS</span> &nbsp;&nbsp; <span style="color:var(--yellow)">9</span> <span style="color:var(--fg)">DOCS</span></div>
    <div><span style="color:var(--yellow)">?</span> <span style="color:var(--fg)">/ F1 — toggle help</span></div>
    <br>
    <div style="color:var(--comment);margin-bottom:8px;letter-spacing:2px">DOCS SCREEN</div>
    <div><span style="color:var(--yellow)">j/k</span> <span style="color:var(--fg)">scroll content down / up</span></div>
    <div><span style="color:var(--yellow)">[/]</span> <span style="color:var(--fg)">previous / next doc</span></div>
    <div><span style="color:var(--yellow)">Esc</span> <span style="color:var(--fg)">close docs viewer</span></div>
    <br>
    <div style="color:var(--comment);margin-bottom:8px;letter-spacing:2px">LABS SCREEN</div>
    <div><span style="color:var(--yellow)">j/k</span> <span style="color:var(--fg)">navigate labs entries</span></div>
    <br>
    <div><span style="color:var(--comment)">press ? to close</span></div>
  </div>
</div>
