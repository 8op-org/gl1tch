---
import { readFileSync, existsSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import path from 'node:path';

const dir = path.dirname(fileURLToPath(import.meta.url));
const gifPath  = path.join(dir, '../../public/glitch-logo.gif');
const htmlPath = path.join(dir, '../generated/glitch-logo.html');

const useGif  = existsSync(gifPath);
const useHtml = !useGif && existsSync(htmlPath);

let logoHtml = '';
if (useHtml) {
  logoHtml = readFileSync(htmlPath, 'utf-8');
}
---
{useGif ? (
  <img
    src="/glitch-logo.gif"
    alt="GL1TCH"
    class="glitch-logo-gif"
    draggable="false"
  />
) : useHtml ? (
  <Fragment set:html={logoHtml} />
) : (
  <pre class="ansi-logo">
<span class="fg-purple"> ██████╗ ██╗     ██╗████████╗ ██████╗██╗  ██╗</span>
<span class="fg-cyan">██╔════╝ ██║     ██║╚══██╔══╝██╔════╝██║  ██║</span>
<span class="fg-purple">██║  ███╗██║     ██║   ██║   ██║     ███████║</span>
<span class="fg-cyan">██║   ██║██║     ██║   ██║   ██║     ██╔══██║</span>
<span class="fg-purple">╚██████╔╝███████╗██║   ██║   ╚██████╗██║  ██║</span>
<span class="fg-cyan"> ╚═════╝ ╚══════╝╚═╝   ╚═╝    ╚═════╝╚═╝  ╚═╝</span>
  </pre>
)}
