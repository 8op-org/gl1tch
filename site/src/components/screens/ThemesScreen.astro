---
import TuiBox from '../TuiBox.astro';

const dark = [
  { name: 'ABS Dark',           accent: '#bd93f9', bg: '#282a36' },
  { name: 'Apprentice',         accent: '#87af87', bg: '#262626' },
  { name: 'Ayu Dark',           accent: '#39bae6', bg: '#0d1017' },
  { name: 'Borland Classic',    accent: '#ffff55', bg: '#0000aa' },
  { name: 'Catppuccin Frappé',  accent: '#8caaee', bg: '#303446' },
  { name: 'Catppuccin Macchiato', accent: '#8aadf4', bg: '#24273a' },
  { name: 'Catppuccin Mocha',   accent: '#cba6f7', bg: '#1e1e2e' },
  { name: 'Cobalt2',            accent: '#ffc600', bg: '#193549' },
  { name: 'Deus',               accent: '#7aa2f7', bg: '#1a1a2e' },
  { name: 'Dracula',            accent: '#ff79c6', bg: '#282a36' },
  { name: 'Everforest Dark',    accent: '#83c092', bg: '#2d353b' },
  { name: 'GitHub Dark',        accent: '#58a6ff', bg: '#0d1117' },
  { name: 'Gotham',             accent: '#195466', bg: '#0c1014' },
  { name: 'Gruvbox Dark',       accent: '#458588', bg: '#282828' },
  { name: 'Iceberg Dark',       accent: '#84a0c6', bg: '#161821' },
  { name: 'Jellybeans',         accent: '#8197bf', bg: '#1c1c1c' },
  { name: 'Kanagawa',           accent: '#7e9cd8', bg: '#1f1f28' },
  { name: 'Kanagawa Dragon',    accent: '#7fb4ca', bg: '#181616' },
  { name: 'Lucario',            accent: '#00bff3', bg: '#2b3e50' },
  { name: 'Miasma',             accent: '#78824b', bg: '#1c1c1c' },
  { name: 'Moonfly',            accent: '#74b2ff', bg: '#080808' },
  { name: 'Night Owl',          accent: '#82aaff', bg: '#011627' },
  { name: 'Nightfly',           accent: '#82aaff', bg: '#011627' },
  { name: 'Nord',               accent: '#88c0d0', bg: '#2e3440' },
  { name: 'Nordic',             accent: '#81a1c1', bg: '#2e3440' },
  { name: 'One Dark',           accent: '#61afef', bg: '#282c34' },
  { name: 'One Half Dark',      accent: '#61afef', bg: '#282c34' },
  { name: 'Panda',              accent: '#ff75b5', bg: '#292a2b' },
  { name: 'Rose Pine',          accent: '#c4a7e7', bg: '#191724' },
  { name: 'Seoul256 Dark',      accent: '#5f87af', bg: '#3a3a3a' },
  { name: 'Shades of Purple',   accent: '#fad000', bg: '#1e1e3f' },
  { name: 'Solarized Dark',     accent: '#268bd2', bg: '#002b36' },
  { name: 'Sonokai',            accent: '#76cce0', bg: '#2c2e34' },
  { name: 'Srcery',             accent: '#68a8e4', bg: '#1c1b19' },
  { name: 'Tender',             accent: '#b3deef', bg: '#282828' },
  { name: 'Tokyo Night',        accent: '#7aa2f7', bg: '#1a1b26' },
  { name: 'Tokyo Night Moon',   accent: '#82aaff', bg: '#222436' },
  { name: 'Tokyo Night Storm',  accent: '#7aa2f7', bg: '#24283b' },
  { name: 'Tomorrow Night',     accent: '#81a2be', bg: '#1d1f21' },
  { name: 'Zenbones Dark',      accent: '#67afc1', bg: '#191919' },
];

const light = [
  { name: 'Ayu Light',          accent: '#399ee6', bg: '#fafafa' },
  { name: 'Catppuccin Latte',   accent: '#1e66f5', bg: '#eff1f5' },
  { name: 'Everforest Light',   accent: '#8da101', bg: '#fdf6e3' },
  { name: 'GitHub Light',       accent: '#0969da', bg: '#ffffff' },
  { name: 'Gruvbox Light',      accent: '#076678', bg: '#fbf1c7' },
  { name: 'Iceberg Light',      accent: '#2d539e', bg: '#e8e9ec' },
  { name: 'Night Owl Light',    accent: '#4876d6', bg: '#fbfbfb' },
  { name: 'Noctis Lux',         accent: '#2d6b97', bg: '#faeedd' },
  { name: 'One Half Light',     accent: '#0184bc', bg: '#fafafa' },
  { name: 'One Light',          accent: '#4078f2', bg: '#fafafa' },
  { name: 'Rosé Pine Dawn',     accent: '#286983', bg: '#faf4ed' },
  { name: 'Seoul256 Light',     accent: '#5f87af', bg: '#d0ccc4' },
  { name: 'Solarized Light',    accent: '#268bd2', bg: '#fdf6e3' },
  { name: 'Tomorrow',           accent: '#4271ae', bg: '#ffffff' },
  { name: 'Zenbones Light',     accent: '#407a9e', bg: '#f0edec' },
];
---
<div class="term-pane-header">
  <div class="tui-panel-header"><span>THEMES</span></div>
</div>
<div class="term-pane" style="overflow-y:auto">

  <h2 class="section-header fg-orange" >// theme picker //</h2>

  <p style="color:var(--fg);font-size:13px;line-height:2;max-width:700px;margin-bottom:4px">
    <span class="fg-yellow">{dark.length + light.length} themes</span> ship with orcai.
    Each one is a full bundle: palette, border style, status bar config, and optional ANSI splash art.
    The live picker previews every theme as you navigate &mdash; no commit until you press enter.
  </p>

  <TuiBox title="PICKER CONTROLS">
    <div class="tui-box-row">
      <div class="tui-box-label fg-cyan">tab</div>
      <div class="tui-box-desc">Switch between Dark and Light theme tabs.</div>
    </div>
    <div class="tui-box-row">
      <div class="tui-box-label fg-cyan">h / l</div>
      <div class="tui-box-desc">Move focus between the two columns.</div>
    </div>
    <div class="tui-box-row">
      <div class="tui-box-label fg-cyan">j / k</div>
      <div class="tui-box-desc">Navigate up and down within a column.</div>
    </div>
    <div class="tui-box-row">
      <div class="tui-box-label fg-cyan">enter</div>
      <div class="tui-box-desc">Apply the highlighted theme and persist to disk.</div>
    </div>
    <div class="tui-box-row">
      <div class="tui-box-label fg-cyan">esc</div>
      <div class="tui-box-desc">Cancel and restore the theme you had when you opened the picker.</div>
    </div>
  </TuiBox>

  <!-- Dark themes -->
  <p style="color:var(--comment);font-size:11px;letter-spacing:2px;margin:20px 0 8px">
    <span class="fg-yellow">DARK</span> &mdash; {dark.length} themes
  </p>
  <div class="theme-swatch-grid">
    {dark.map(t => (
      <div class="theme-swatch-item">
        <span class="theme-swatch-dot" style={`background:${t.accent};box-shadow:0 0 6px ${t.accent}55`}></span>
        <span class="theme-swatch-bg" style={`background:${t.bg}`}></span>
        <span class="theme-swatch-name">{t.name}</span>
      </div>
    ))}
  </div>

  <!-- Light themes -->
  <p style="color:var(--comment);font-size:11px;letter-spacing:2px;margin:20px 0 8px">
    <span class="fg-yellow">LIGHT</span> &mdash; {light.length} themes
  </p>
  <div class="theme-swatch-grid">
    {light.map(t => (
      <div class="theme-swatch-item">
        <span class="theme-swatch-dot" style={`background:${t.accent};box-shadow:0 0 6px ${t.accent}55`}></span>
        <span class="theme-swatch-bg" style={`background:${t.bg};border:1px solid var(--comment)`}></span>
        <span class="theme-swatch-name">{t.name}</span>
      </div>
    ))}
  </div>

  <p style="color:var(--comment);font-size:11px;margin-top:20px">
    <span class="fg-yellow">&rarr;</span> Press <span class="fg-yellow">T</span> in the TUI to open the picker &nbsp;&middot;&nbsp;
    <span class="fg-yellow">1</span> for home &nbsp;&middot;&nbsp;
    <span class="fg-yellow">2</span> for about
  </p>
</div>

<style>
.theme-swatch-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 4px 12px;
  max-width: 700px;
}

.theme-swatch-item {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  color: var(--fg);
  padding: 2px 0;
}

.theme-swatch-dot {
  display: inline-block;
  width: 10px;
  height: 10px;
  border-radius: 50%;
  flex-shrink: 0;
}

.theme-swatch-bg {
  display: inline-block;
  width: 10px;
  height: 10px;
  border-radius: 2px;
  flex-shrink: 0;
}

.theme-swatch-name {
  color: var(--comment);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
</style>
