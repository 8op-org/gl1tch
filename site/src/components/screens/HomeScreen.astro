---
import SysinfoBox from '../SysinfoBox.astro';
import AnsiLogo from '../AnsiLogo.astro';
---
<div class="term-pane-header">
  <div class="tui-panel-header"><span>ORCAI — ABBS</span></div>
</div>

<div class="term-pane">
  <section class="hero">

    <!-- 1. Hero subtitle -->
    <div class="hero-subtitle fg-comment" style="font-size:11px;letter-spacing:3px;margin-bottom:12px">// ABBS NODE 001 // CONNECTED //</div>

    <!-- 2. ANSI logo -->
    <AnsiLogo />

    <!-- 3. Typewriter -->
    <div class="typewriter-wrap" style="margin:10px 0 4px">
      <span id="typewriter"></span>
    </div>

    <!-- 4. Sysinfo -->
    <SysinfoBox />

    <!-- 5. Hacker-voice taglines -->
    <ul class="tui-taglines">
      <li>your agents. your terminal. your rules.</li>
      <li>pipelines are YAML. steps are typed. no glue code.</li>
      <li>local models. no API key. no cloud lock-in.</li>
      <li>everything runs where you do — in the terminal.</li>
    </ul>

    <!-- 6. Feature highlights grid -->
    <div class="feature-grid">
      <div class="feature-grid-item">
        <span class="feat-label">PIPELINES</span>
        <span class="feat-desc">YAML-defined step chains</span>
      </div>
      <div class="feature-grid-item">
        <span class="feat-label">AGENT RUNNER</span>
        <span class="feat-desc">cron + on-demand runs</span>
      </div>
      <div class="feature-grid-item">
        <span class="feat-label">BRAIN CONTEXT</span>
        <span class="feat-desc">inject docs, files, URLs</span>
      </div>
      <div class="feature-grid-item">
        <span class="feat-label">LOCAL AI</span>
        <span class="feat-desc">Ollama, no cloud required</span>
      </div>
      <div class="feature-grid-item">
        <span class="feat-label">THEMES</span>
        <span class="feat-desc">Apprentice &amp; more built-in</span>
      </div>
      <div class="feature-grid-item">
        <span class="feat-label">KEYBOARD NAV</span>
        <span class="feat-desc">full TUI, zero mouse needed</span>
      </div>
    </div>

    <!-- 7. Ollama supercharger callout -->
    <div class="tui-callout">
      <span class="tui-callout-title">OLLAMA SUPERCHARGER</span>
      <p>Run fully local AI workflows.<br/>
      No API key required.<br/>
      Pull a model. Point orcai at it.</p>
      <p><span class="fg-cyan">ollama pull qwen2.5-coder:latest</span><br/>
      <span class="fg-cyan">ollama pull llama3.2</span></p>
    </div>

    <!-- 8. Bottom nav hint -->
    <p style="color:var(--comment);font-size:11px;margin-top:14px;letter-spacing:2px">PRESS <span class="fg-yellow">[ENTER]</span> TO CONNECT &nbsp;·&nbsp; <span class="fg-yellow">[3]</span> GET STARTED &nbsp;·&nbsp; <span class="fg-yellow">[8]</span> LABS &nbsp;·&nbsp; <span class="fg-yellow">[?]</span> HELP</p>

  </section>
</div>
