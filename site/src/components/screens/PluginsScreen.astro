---
import TuiBox from '../TuiBox.astro';

const plugins = [
  { name: 'ollama',          kind: 'agent', desc: 'Local models via the Ollama daemon. Models discovered at runtime.',         install: 'orcai-ollama binary + ollama.yaml' },
  { name: 'claude',          kind: 'agent', desc: 'Claude AI via the claude CLI. Opus, Sonnet, Haiku.',                        install: 'orcai-claude binary + claude.yaml'  },
  { name: 'gemini',          kind: 'agent', desc: 'Google Gemini via the gemini CLI. Flash and Pro models.',                   install: 'orcai-gemini binary + gemini.yaml'  },
  { name: 'github-copilot',  kind: 'agent', desc: 'GitHub Copilot via gh extension.',                                          install: 'orcai-github-copilot + yaml'        },
  { name: 'opencode',        kind: 'agent', desc: 'OpenCode AI assistant.',                                                    install: 'orcai-opencode binary + yaml'       },
  { name: 'gh',              kind: 'tool',  desc: 'GitHub CLI wrapper. Pass any gh subcommand via vars.args.',                 install: 'gh.yaml only (no binary)'          },
  { name: 'jq',              kind: 'tool',  desc: 'Apply a jq filter to JSON input. Filter via vars.filter.',                  install: 'jq.yaml only (no binary)'          },
];
---
<div class="term-pane-header">
  <div class="tui-panel-header"><span>PLUGINS</span></div>
</div>
<div class="term-pane" style="overflow-y:auto">
  <h2 class="section-header fg-green">// plugin architecture //</h2>
  <p style="color:var(--fg);font-size:13px;line-height:2;max-width:700px;margin-bottom:4px">
    Plugins are YAML sidecar files in <span class="fg-cyan">~/.config/orcai/wrappers/</span>.
    Two kinds: <span class="fg-green">agent</span> plugins drive AI providers,
    <span class="fg-yellow">tool</span> plugins wrap CLI tools.
    No registry, no daemon, no installation ceremony beyond dropping a file.
  </p>

  <!-- Available plugins -->
  <TuiBox title="BUNDLED PLUGINS">
    {plugins.map(p => (
      <div class="tui-box-row">
        <div class={`tui-box-label ${p.kind === 'agent' ? 'fg-green' : 'fg-yellow'}`}>{p.name}</div>
        <div class="tui-box-desc">
          <span class="fg-comment">[{p.kind}]</span> {p.desc}<br/>
          <span style="color:var(--comment);font-size:10px">{p.install}</span>
        </div>
      </div>
    ))}
  </TuiBox>

  <!-- YAML sidecar format -->
  <p style="color:var(--fg);font-size:13px;line-height:2;max-width:700px;margin:16px 0 4px">
    Agent plugins declare their models. Tool plugins wrap a shell command.
    Drop the YAML in <span class="fg-cyan">~/.config/orcai/wrappers/</span> and orcai discovers it on next launch.
  </p>

  <p style="color:var(--comment);font-size:11px;margin:12px 0 4px">// agent sidecar (kind: agent)</p>
  <pre class="code-block yaml-block"><code class="copy-target">name: ollama
description: "Run local AI models via the Ollama daemon"
kind: agent
command: orcai-ollama
models:
  - id: llama3.2:latest
    label: "Llama 3.2"
  - id: qwen2.5-coder:latest
    label: "Qwen 2.5 Coder"</code></pre>

  <p style="color:var(--comment);font-size:11px;margin:12px 0 4px">// tool sidecar (kind: tool)</p>
  <pre class="code-block yaml-block"><code class="copy-target">name: jq
description: "Apply a jq filter to JSON input"
kind: tool
command: sh
args:
  - "-c"
  - 'jq "$&#123;ORCAI_FILTER:-&#46;&#125;"'</code></pre>

  <!-- gRPC interface -->
  <TuiBox title="GRPC SIDECAR — FULL CONTROL">
    <div class="tui-box-row">
      <div class="tui-box-label fg-purple">interface</div>
      <div class="tui-box-desc">Implement the Plugin gRPC interface in Go for full control over execution, streaming, and output types.</div>
    </div>
    <div class="tui-box-row">
      <div class="tui-box-label fg-purple">discovery</div>
      <div class="tui-box-desc">Binary on PATH + YAML descriptor. orcai spawns and communicates via gRPC — no coupling to orcai internals.</div>
    </div>
  </TuiBox>

  <pre class="code-block" style="margin-top:0"><code>type Plugin interface &#123;
    Describe() PluginInfo
    Execute(ctx context.Context, input Input) (Output, error)
&#125;</code></pre>

  <p style="color:var(--comment);font-size:11px;margin-top:16px">
    <span class="fg-yellow">&rarr;</span> Press <span class="fg-yellow">5</span> for pipelines &nbsp;&middot;&nbsp; <span class="fg-yellow">3</span> for getting started
  </p>
</div>
