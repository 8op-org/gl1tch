---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<div class="tui-box">
  <div class="tui-box-title">[ <span class="fg-yellow">{title}</span> ]</div>
  <slot />
</div>

<style>
/* .tui-box and .tui-box-title are on this component's own elements — scoped is fine */
.tui-box {
  border: 1px solid var(--comment);
  position: relative;
  padding: 14px 18px 16px;
  margin: 16px 0;
  max-width: 700px;
}

.tui-box-title {
  position: absolute;
  top: -8px;
  left: 10px;
  background: var(--bg);
  padding: 0 6px;
  font-size: 11px;
  color: var(--comment);
  line-height: 1;
  letter-spacing: 0.05em;
}
</style>
