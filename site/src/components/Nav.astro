---
const navItems = [
  { key: '1', label: 'HOME',        screen: 'home' },
  { key: '2', label: 'ABOUT',       screen: 'about' },
  { key: '3', label: 'GET STARTED', screen: 'getting-started' },
  { key: '4', label: 'PLUGINS',     screen: 'plugins' },
  { key: '5', label: 'PIPELINES',   screen: 'pipelines' },
  { key: '6', label: 'CHANGELOG',   screen: 'changelog' },
  { key: '7', label: 'THEMES',      screen: 'themes' },
  { key: '8', label: 'LABS',        screen: 'labs' },
  { key: '9', label: 'DOCS',        screen: 'docs' },
];
---
<div class="tui-titlebar" role="banner">
  <div class="tui-titlebar-brand">&#8779;&#8779;&#8779; ORCAI &mdash; ABBS &#8779;&#8779;&#8779;</div>
  <nav class="tui-nav" aria-label="Main navigation">
    {navItems.map((item, i) => (
      <>
        {i > 0 && <span class="tui-sep">&nbsp;&middot;&nbsp;</span>}
        <button
          class="tui-nav-btn"
          data-nav-screen={item.screen}
          onclick={`KeyboardRouter.switchScreen('${item.screen}')`}
        ><span class="tui-nav-key">{item.key}</span> {item.label}</button>
      </>
    ))}
    <span class="tui-sep">&nbsp;&middot;&nbsp;</span>
    <button class="tui-nav-btn" onclick="KeyboardRouter.toggleHelp()">
      <span class="tui-nav-key">?</span> HELP
    </button>
  </nav>
  <div class="tui-titlebar-status">
    <span class="online">&#11044;</span>&nbsp;ONLINE&nbsp;&nbsp;|&nbsp;&nbsp;<span class="clock"></span>
  </div>
</div>
