# Copy this file to .env and fill in your values
# .env is gitignored and will never be committed

# Required for GitHub MCP server (.mcp.json)
# Generate with: echo "GITHUB_PERSONAL_ACCESS_TOKEN=$(gh auth token)" > .env
GITHUB_PERSONAL_ACCESS_TOKEN=

# Optional: Google Cloud (for Gemini/Vertex AI support)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=
GOOGLE_APPLICATION_CREDENTIALS=

# Optional: Ollama (defaults to http://localhost:11434 if not set)
# OLLAMA_HOST=http://localhost:11434
